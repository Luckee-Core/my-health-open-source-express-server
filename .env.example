# =============================================================================
# My Health Express API — environment variables
# Copy to .env and set your local Postgres connection string.
# =============================================================================

# Server
PORT=3009
NODE_ENV=development

# Postgres (SERVER-ONLY — never expose in browser NEXT_PUBLIC_* vars)
# Example (Homebrew Postgres on Mac, database my_health):
# DATABASE_URL=postgresql://YOUR_MAC_USERNAME@127.0.0.1:5432/my_health
DATABASE_URL=

# Optional connection pool cap (default 10)
# PG_POOL_MAX=10

# Future production hardening (not required for local OSS dev)
# CORS_ORIGINS=http://localhost:3000
