# =============================================================================
# My Health Express API — environment variables
# Copy to .env and fill in Supabase credentials.
# =============================================================================

# Server
PORT=3009
NODE_ENV=development

# Supabase (SERVER-ONLY — never expose in browser NEXT_PUBLIC_* vars)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alias also accepted in code: SUPABASE_SERVICE_KEY=

# Future production hardening (not required for local OSS dev)
# CORS_ORIGINS=http://localhost:3000
